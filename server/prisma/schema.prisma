// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  admin
  supervisor
  agent
  readonly
  customer
}

enum TicketStatus {
  new
  processing
  open
  in_progress
  escalated
  resolved
  closed
}

enum SenderType {
  agent
  customer
}

enum VirusScanStatus {
  pending
  clean
  infected
  skipped
}

enum TicketCategory {
  general_question
  technical_question
  refund_request
}

enum MacroVisibility {
  global
  personal
}

enum TicketPriority {
  low
  medium
  high
  urgent
}

enum TicketSeverity {
  sev4
  sev3
  sev2
  sev1
}

enum TicketImpact {
  low
  medium
  high
}

enum TicketUrgency {
  low
  medium
  high
}

enum KbArticleStatus {
  draft
  published
}

enum KbReviewStatus {
  draft
  in_review
  approved
  archived
}

enum KbVisibility {
  public
  internal
}

enum TicketType {
  incident
  service_request
  problem
  change_request
}

enum EscalationReason {
  first_response_sla_breach
  resolution_sla_breach
  urgent_priority
  sev1_severity
  manual
  rule_triggered
}

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean
  image            String?
  role             Role    @default(agent)
  globalTicketView Boolean @default(false)
  createdAt        DateTime
  updatedAt        DateTime
  deletedAt        DateTime?
  sessions        Session[]
  accounts        Account[]
  assignedTickets     Ticket[]
  replies             Reply[]
  notes               Note[]
  auditEvents         AuditEvent[]
  macros              Macro[]
  kbArticlesAuthored      KbArticle[]        @relation("KbArticleAuthor")
  kbArticlesOwned         KbArticle[]        @relation("KbArticleOwner")
  kbArticlesReviewed      KbArticle[]        @relation("KbArticleReviewer")
  kbArticleVersions       KbArticleVersion[]
  uploadedAttachments Attachment[]
  teamMemberships     TeamMember[]
  preference          UserPreference?
  capacityProfile     AgentCapacityProfile?
  dashboards          DashboardConfig[]
  savedTicketViews    SavedTicketView[]
  savedAssetViews     SavedAssetView[]
  assetMovements      AssetMovement[] @relation("AssetMovementPerformedBy")
  createdContracts    Contract[]      @relation("ContractCreatedBy")
  // Incident management relations
  incidentsCommanded    Incident[]          @relation("IncidentCommander")
  incidentsAssigned     Incident[]          @relation("IncidentAssignee")
  incidentsCreated      Incident[]          @relation("IncidentCreatedBy")
  incidentUpdates       IncidentUpdate[]    @relation("IncidentUpdateAuthor")
  incidentAttachments   IncidentAttachment[] @relation("IncidentAttachmentUploader")
  incidentEvents        IncidentEvent[]     @relation("IncidentEventActor")
  // Approval engine relations
  approvalRequestsMade  ApprovalRequest[]   @relation("ApprovalRequestedBy")
  approvalStepsAssigned ApprovalStep[]      @relation("ApprovalStepApprover")
  approvalDecisions     ApprovalDecision[]  @relation("ApprovalDecisionBy")
  approvalEvents        ApprovalEvent[]     @relation("ApprovalEventActor")
  // Service Request relations
  requestsSubmitted     ServiceRequest[]    @relation("RequestSubmittedBy")
  requestsAssigned      ServiceRequest[]    @relation("RequestAssignee")
  requestsCreated       ServiceRequest[]    @relation("RequestCreatedBy")
  fulfillmentTasksAssigned FulfillmentTask[] @relation("FulfillmentTaskAssignee")
  fulfillmentTasksCreated  FulfillmentTask[] @relation("FulfillmentTaskCreatedBy")
  requestEvents         RequestEvent[]      @relation("RequestEventActor")
  // Problem management relations
  problemsOwned         Problem[]           @relation("ProblemOwner")
  problemsAssigned      Problem[]           @relation("ProblemAssignee")
  problemNotes          ProblemNote[]       @relation("ProblemNoteAuthor")
  problemIncidentLinks  ProblemIncidentLink[] @relation("ProblemLinkLinkedBy")
  problemTicketLinks    ProblemTicketLink[]   @relation("ProblemTicketLinkedBy")
  problemEvents         ProblemEvent[]      @relation("ProblemEventActor")
  // CMDB relations
  cisOwned              ConfigItem[]        @relation("CiOwner")
  cisCreated            ConfigItem[]        @relation("CiCreatedBy")
  ciEvents              CiEvent[]           @relation("CiEventActor")
  // Catalog relations
  catalogItemsCreated   CatalogItem[]       @relation("CatalogItemCreatedBy")
  // Notification relations
  notifications         Notification[]      @relation("NotificationRecipient")
  // Organization account management
  accountManagerFor     Organization[]      @relation("OrgAccountManager")
  // Scenario automations
  scenariosCreated      ScenarioDefinition[] @relation("ScenarioCreatedBy")
  scenarioExecutions    ScenarioExecution[]  @relation("ScenarioInvokedBy")
  // Enterprise Automation Platform
  automationRulesCreated  AutomationRule[]   @relation("AutomationRuleCreatedBy")
  automationRulesUpdated  AutomationRule[]   @relation("AutomationRuleUpdatedBy")
  outboundWebhooksCreated OutboundWebhook[]  @relation("OutboundWebhookCreatedBy")
  // Change Management relations
  changesAssigned       Change[]             @relation("ChangeAssignee")
  changesCreated        Change[]             @relation("ChangeCreatedBy")
  changeTasksAssigned   ChangeTask[]         @relation("ChangeTaskAssignee")
  changeTasksCompleted  ChangeTask[]         @relation("ChangeTaskCompletedBy")
  changeEvents          ChangeEvent[]        @relation("ChangeEventActor")
  changeCiLinks         ChangeCiLink[]       @relation("ChangeCiLinkLinkedBy")
  changeAttachments     ChangeAttachment[]   @relation("ChangeAttachmentUploader")
  templates             Template[]
  formDefinitions       FormDefinition[]
  customFields          CustomField[]
  cabGroupsCreated      CabGroup[]
  cabMemberships        CabMember[]
  ticketTypesCreated       TicketTypeConfig[]
  ticketStatusesCreated    TicketStatusConfig[]
  escalationRulesCreated   EscalationRule[]
  ticketFollows            TicketFollower[]
  entityFollows            EntityFollower[]
  // Analytics relations
  savedReports             SavedReport[]    @relation("SavedReportOwner")
  reportSchedules          ReportSchedule[] @relation("ReportScheduleCreatedBy")
  reportSharesGiven        ReportShare[]    @relation("ReportSharedBy")
  reportSharesReceived     ReportShare[]    @relation("ReportSharedTo")
  // Asset management relations
  assetsOwned              Asset[]          @relation("AssetOwner")
  assetsAssigned           Asset[]          @relation("AssetAssignee")
  assetsCreated            Asset[]          @relation("AssetCreatedBy")
  assetAssignments         AssetAssignment[]    @relation("AssetAssignmentUser")
  assetAssignedBy          AssetAssignment[]    @relation("AssetAssignedBy")
  assetEvents              AssetEvent[]         @relation("AssetEventActor")
  assetRelationshipsCreated AssetRelationship[] @relation("AssetRelCreatedBy")
  // Discovery & sync relations
  discoveryConnectorsCreated DiscoveryConnector[] @relation("DiscoveryConnectorCreatedBy")
  discoverySyncRunsTriggered DiscoverySyncRun[]   @relation("DiscoverySyncRunTriggeredBy")
  // Software & SaaS governance relations
  softwareLicensesOwned    SoftwareLicense[]    @relation("SoftwareLicenseOwner")
  softwareLicensesCreated  SoftwareLicense[]    @relation("SoftwareLicenseCreatedBy")
  licenseAssignments       LicenseAssignment[]  @relation("LicenseAssignmentUser")
  licenseAssignmentsGiven  LicenseAssignment[]  @relation("LicenseAssignmentBy")
  saasSubscriptionsOwned   SaaSSubscription[]   @relation("SaaSSubscriptionOwner")
  saasSubscriptionsCreated SaaSSubscription[]   @relation("SaaSSubscriptionCreatedBy")
  saasUserAssignments      SaaSUserAssignment[] @relation("SaaSUserAssignmentUser")
  saasUserAssignmentsGiven SaaSUserAssignment[] @relation("SaaSUserAssignmentBy")
  escalatedTickets         Ticket[]             @relation("EscalatedToUser")
  // Duty Plan relations
  dutyPlansCreated         DutyPlan[]           @relation("DutyPlanCreatedBy")
  dutyAssignments          DutyAssignment[]     @relation("DutyAssignmentAgent")
  dutyPlanRoles            DutyPlanRole[]       @relation("DutyPlanRoleUser")
  dutyPlanRolesGranted     DutyPlanRole[]       @relation("DutyPlanRoleGrantedBy")

  @@map("user")
}

model UserPreference {
  userId            String   @id
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Profile extras
  jobTitle          String?
  phone             String?
  // Locale
  language          String   @default("en")
  timezone          String   @default("UTC")
  dateFormat        String   @default("MMM d, yyyy")
  timeFormat        String   @default("12h")
  // UI
  theme             String   @default("system")
  sidebarCollapsed  Boolean  @default(false)
  defaultDashboard  String   @default("overview")
  ticketListDensity String   @default("comfortable")
  // Reply signature (HTML)
  signature         String?
  updatedAt         DateTime @updatedAt

  @@map("user_preference")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
}

model Organization {
  id               Int        @id @default(autoincrement())
  name             String
  domain           String?    @unique
  notes            String?
  // ── Enrichment ───────────────────────────────────────────────────────────
  website          String?    @map("website")
  industry         String?    @map("industry")
  employeeCount    Int?       @map("employee_count")
  country          String?    @map("country")
  address          String?    @map("address")
  // Support configuration
  supportTier      String     @default("standard") @map("support_tier")
  accountManagerId String?    @map("account_manager_id")
  accountManager   User?      @relation("OrgAccountManager", fields: [accountManagerId], references: [id])
  isActive         Boolean    @default(true) @map("is_active")
  // ─────────────────────────────────────────────────────────────────────────
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  customers  Customer[]
  entitlements ServiceEntitlement[]

  @@index([supportTier])
  @@index([isActive])
  @@map("organization")
}

model Customer {
  id             Int           @id @default(autoincrement())
  email          String        @unique
  name           String
  organizationId Int?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  notes          String?
  // ── Enrichment ───────────────────────────────────────────────────────────
  phone            String?  @map("phone")
  jobTitle         String?  @map("job_title")
  timezone         String   @default("UTC") @map("timezone")
  language         String   @default("en") @map("language")
  preferredChannel String?  @map("preferred_channel")
  isVip            Boolean  @default(false) @map("is_vip")
  supportTier      String   @default("standard") @map("support_tier")
  avatarUrl        String?  @map("avatar_url")
  // ─────────────────────────────────────────────────────────────────────────
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  tickets          Ticket[]
  serviceRequests  ServiceRequest[]

  @@index([isVip])
  @@index([supportTier])
  @@index([organizationId])
  @@map("customer")
}

/**
 * ServiceEntitlement — records the support contract or service tier for an organization.
 * Placeholder model: gates, limits, and SLA policies are wired up as entitlements mature.
 *
 * tier: "free" | "standard" | "premium" | "enterprise"
 * slaPolicy: name of an SLA policy to apply to tickets from this org
 */
model ServiceEntitlement {
  id             Int          @id @default(autoincrement())
  organizationId Int          @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tier           String       @default("standard") @map("tier")
  maxUsers       Int?         @map("max_users")
  slaPolicy      String?      @map("sla_policy")
  features       String[]     @map("features")
  startsAt       DateTime?    @map("starts_at")
  expiresAt      DateTime?    @map("expires_at")
  isActive       Boolean      @default(true) @map("is_active")
  notes          String?      @map("notes")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@index([organizationId, isActive])
  @@map("service_entitlement")
}

model TicketCounter {
  series    String  @map("series")
  periodKey String  @default("") @map("period_key")
  lastValue Int     @default(0)  @map("last_value")

  @@id([series, periodKey])
  @@map("ticket_counter")
}

model Ticket {
  id           Int             @id @default(autoincrement())
  /// Immutable human-readable display ID. Format: {PREFIX}{dateSegment?}{zeroPaddedSeq}.
  /// Generated at creation time from ticket_counter. Never changes after assignment.
  ticketNumber String          @unique @map("ticket_number")
  subject      String
  body         String
  bodyHtml     String?
  status       TicketStatus    @default(new)
  ticketType   TicketType?
  affectedSystem String?
  category     TicketCategory?
  priority     TicketPriority?
  severity     TicketSeverity?
  impact       TicketImpact?
  urgency      TicketUrgency?
  senderName   String
  senderEmail  String
  // Customer entity — resolved from senderEmail at ticket-creation time.
  // Kept nullable so that legacy tickets (pre-migration) are not broken.
  customerId   Int?
  customer     Customer?       @relation(fields: [customerId], references: [id])
  assignedToId String?
  assignedTo   User?           @relation(fields: [assignedToId], references: [id])
  // Team — which support team/inbox this ticket belongs to. Null = default inbox.
  // @map keeps the DB column name (queueId) while TypeScript uses teamId.
  teamId       Int?            @map("queueId")
  team         Team?           @relation(fields: [teamId], references: [id], onDelete: SetNull)
  // Email threading: Message-ID header from the original inbound email.
  // Used to set In-Reply-To / References when sending agent replies.
  emailMessageId String?
  // Time-supervisor tracking — stamped at activity points for efficient supervisor scanning
  lastAgentReplyAt    DateTime? @map("last_agent_reply_at")    // most recent agent reply timestamp
  lastCustomerReplyAt DateTime? @map("last_customer_reply_at") // most recent customer reply timestamp
  statusChangedAt     DateTime? @map("status_changed_at")      // when status was last changed
  // Intake routing — populated from inbound email headers at creation time
  emailTo        String?  @map("email_to")        // To: header (recipient mailbox address)
  emailCc        String?  @map("email_cc")         // CC: header (comma-separated raw value)
  emailReplyTo   String?  @map("email_reply_to")   // Reply-To: header
  isAutoReply    Boolean  @default(false) @map("is_auto_reply")   // X-Auto-Submitted / Auto-Submitted detection
  isBounce       Boolean  @default(false) @map("is_bounce")       // delivery failure / NDR detection
  isSpam         Boolean  @default(false) @map("is_spam")         // marked spam by intake rule
  isQuarantined  Boolean  @default(false) @map("is_quarantined")  // held for manual review
  mailboxAlias   String?  @map("mailbox_alias")    // human-readable mailbox alias (e.g. "support", "billing")
  // Channel that created this ticket: "email", "portal", "agent", or null for legacy rows.
  source         String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  replies      Reply[]
  attachments  Attachment[]

  // SLA: deadlines are calculated from priority at ticket creation.
  // Recalculated when priority changes. Null = no SLA target set yet.
  firstResponseDueAt  DateTime?
  resolutionDueAt     DateTime?

  // SLA: actuals — stamped when the milestone is reached.
  firstRespondedAt    DateTime?
  resolvedAt          DateTime?

  // Persistent breach flag. Once true, stays true for historical reporting
  // even if the ticket is later resolved.
  slaBreached         Boolean   @default(false)

  // Escalation — isEscalated is a live flag; escalationEvents is the full audit trail.
  isEscalated         Boolean            @default(false)
  escalatedAt         DateTime?
  // First reason that triggered escalation (subsequent reasons go in escalationEvents only)
  escalationReason    EscalationReason?
  escalationEvents    EscalationEvent[]
  // Manual escalation targets — the team/agent the ticket was escalated to
  escalatedToTeamId   Int?               @map("escalated_to_team_id")
  escalatedToTeam     Team?              @relation("EscalatedToTeam", fields: [escalatedToTeamId], references: [id], onDelete: SetNull)
  escalatedToUserId   String?            @map("escalated_to_user_id")
  escalatedToUser     User?              @relation("EscalatedToUser", fields: [escalatedToUserId], references: [id], onDelete: SetNull)

  notes               Note[]
  auditEvents         AuditEvent[]
  csatRating          CsatRating?
  ciLinks             TicketCiLink[]

  // Linked ITIL records — populated when ticketType is incident or service_request.
  // One-to-one: each ticket links to at most one Incident and one ServiceRequest.
  linkedIncidentId       Int?            @unique @map("linked_incident_id")
  linkedIncident         Incident?       @relation("TicketLinkedIncident", fields: [linkedIncidentId], references: [id])
  linkedServiceRequestId Int?            @unique @map("linked_service_request_id")
  linkedServiceRequest   ServiceRequest? @relation("TicketLinkedServiceRequest", fields: [linkedServiceRequestId], references: [id])
  scenarioExecutions     ScenarioExecution[]
  problemLinks           ProblemTicketLink[]
  assetLinks             AssetTicketLink[]
  followers              TicketFollower[]
  // Merge — when a ticket is merged into another, mergedIntoId is set and the
  // ticket is closed. The parent sees its child tickets via mergedTickets.
  mergedIntoId           Int?                @map("merged_into_id")
  mergedInto             Ticket?             @relation("MergedTickets", fields: [mergedIntoId], references: [id])
  mergedTickets          Ticket[]            @relation("MergedTickets")
  mergedAt               DateTime?           @map("merged_at")
  customFields           Json                @default("{}")
  customStatusId         Int?
  customStatus           TicketStatusConfig? @relation(fields: [customStatusId], references: [id], onDelete: SetNull)
  customTicketTypeId     Int?
  customTicketType       TicketTypeConfig?   @relation(fields: [customTicketTypeId], references: [id], onDelete: SetNull)
  // SLA pause tracking — set when ticket enters an on_hold custom status; cleared on resume.
  slaPausedAt            DateTime?
  // Accumulated pause time in minutes (historical total, for reporting).
  slaPausedMinutes       Int                 @default(0)

  deletedAt     DateTime? @map("deleted_at")
  deletedById   String?   @map("deleted_by_id")
  deletedByName String?   @map("deleted_by_name")

  @@index([deletedAt])
  @@index([status, updatedAt])
  @@index([lastAgentReplyAt])
  @@index([lastCustomerReplyAt])
  @@map("ticket")
}

// ── ITSM module following ─────────────────────────────────────────────────────

enum EntityFollowerType {
  incident
  change
  service_request
  problem
}

/// Polymorphic follower record — one row per (entityType, entityId, userId).
/// Agents who follow an ITSM record receive in-app notifications on status changes.
model EntityFollower {
  entityType  EntityFollowerType @map("entity_type")
  entityId    Int                @map("entity_id")
  userId      String             @map("user_id")
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime           @default(now())

  @@id([entityType, entityId, userId])
  @@index([userId])
  @@index([entityType, entityId])
  @@map("entity_follower")
}

model EscalationEvent {
  id        Int              @id @default(autoincrement())
  ticketId  Int
  ticket    Ticket           @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  reason    EscalationReason
  createdAt DateTime         @default(now())

  @@map("escalation_event")
}

/// Agent subscription to a ticket — followed agents receive in-app notifications
/// whenever the ticket status changes.
model TicketFollower {
  ticketId  Int      @map("ticket_id")
  userId    String   @map("user_id")
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([ticketId, userId])
  @@index([userId])
  @@map("ticket_follower")
}

model Reply {
  id             Int          @id @default(autoincrement())
  body           String
  bodyHtml       String?
  senderType     SenderType
  ticketId       Int
  ticket         Ticket       @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId         String?
  user           User?        @relation(fields: [userId], references: [id])
  // Email threading: Message-ID for this specific reply (inbound from header, outbound generated).
  emailMessageId String?
  // ── Channel metadata ────────────────────────────────────────────────────
  // channel: the intake or outbound channel for this message.
  // Values: "email" | "portal" | "api" | "chat" | "whatsapp" | "slack_teams" | "voice" | "social"
  // Null on legacy rows pre-omnichannel.
  channel        String?      @map("channel")
  // channelMeta: channel-specific structured data (e.g. WhatsApp waId, email Message-ID chain).
  // Kept as untyped JSON so channel adapters can store what they need without migrations.
  channelMeta    Json?        @map("channel_meta")
  // ── Reply addressing ─────────────────────────────────────────────────────
  replyType      String?      // "reply_all" | "reply_sender" | "forward"
  cc             String?      // comma-separated CC addresses
  bcc            String?      // comma-separated BCC addresses
  forwardTo      String?      // recipient address for forwarded messages
  quotedBody     String?      // plain-text snapshot of the message being replied to / forwarded
  quotedHtml     String?      // HTML snapshot of the message being replied to / forwarded
  // ────────────────────────────────────────────────────────────────────────
  createdAt      DateTime     @default(now())
  attachments    Attachment[]

  @@index([channel])
  @@map("reply")
}

/**
 * Attachment — file attached to a ticket's original message or a specific reply.
 *
 * Storage assumptions:
 *   - Files are stored on disk in UPLOAD_DIR (env var, default ./uploads).
 *   - storageKey is a UUID-based filename — original names are never used as paths.
 *   - To swap to object storage (S3 / R2 / GCS), replace server/src/lib/storage.ts only.
 *   - Notes intentionally have no Attachment relation — internal notes must never
 *     include external file transfers.
 *
 * Scoping:
 *   - ticketId is always set; provides CASCADE delete when a ticket is removed.
 *   - replyId is null for ticket-level attachments (original inbound email).
 *   - replyId is set for reply-level attachments (inbound email replies or agent replies).
 */
model Attachment {
  id              Int             @id @default(autoincrement())
  filename        String
  mimeType        String
  size            Int
  storageKey      String          @unique
  /// Which backend holds this file: "local", "s3", "gcs", "r2".
  /// Used to route load/remove calls to the correct provider on retrieval.
  storageProvider String          @default("local")
  /// SHA-256 hex digest of the raw file bytes. Null for legacy uploads
  /// created before this column was added.
  checksum        String?
  /// Result of the virus scan. "skipped" means no scanner was configured.
  /// Block downloads when status is "infected" or optionally when "pending".
  virusScanStatus VirusScanStatus @default(skipped)
  ticketId        Int
  ticket          Ticket          @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  replyId         Int?
  reply           Reply?          @relation(fields: [replyId], references: [id], onDelete: SetNull)
  uploadedById    String?
  uploadedBy      User?           @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  createdAt       DateTime        @default(now())

  @@index([ticketId])
  @@index([replyId])
  @@index([virusScanStatus])
  @@map("attachment")
}

model Note {
  id               Int      @id @default(autoincrement())
  body             String
  bodyHtml         String?
  isPinned         Boolean  @default(false)
  ticketId         Int
  ticket           Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  // authorId is nullable to allow system/workflow-generated notes (no human actor)
  authorId         String?
  author           User?    @relation(fields: [authorId], references: [id])
  // Future: store @mentioned agent IDs for notification routing
  mentionedUserIds String[] @default([])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("note")
}

/**
 * AuditEvent — append-only record of every significant action on a ticket.
 *
 * Design principles:
 *  - action is a dot-namespaced string constant ("ticket.created", "reply.created", etc.)
 *    — easy to filter, index, and extend without schema changes.
 *  - actorId null means the action was performed by the system / background job.
 *  - meta is a free-form JSON object. Convention: include "from"/"to" for field
 *    changes, "reason" for escalations, "id" for related record references.
 *    Never store secrets, passwords, or auth tokens in meta.
 *  - Cascades on ticket delete so audit history is removed with the ticket.
 */
/**
 * Macro — a saved reply template with optional variable placeholders.
 *
 * Supported placeholders (resolved client-side at insertion time):
 *   {{customer_name}}   first name of the ticket sender
 *   {{customer_email}}  sender email address
 *   {{ticket_id}}       numeric ticket ID
 *   {{agent_name}}      name of the currently logged-in agent
 */
model Macro {
  id          Int              @id @default(autoincrement())
  title       String
  body        String
  category    TicketCategory?
  isActive    Boolean          @default(true)
  isSystem    Boolean          @default(false)
  visibility  MacroVisibility  @default(global)
  createdById String
  createdBy   User             @relation(fields: [createdById], references: [id])
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@map("macro")
}

enum FormEntityType {
  ticket
  request
  change
