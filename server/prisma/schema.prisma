/**
 * Team — a named support team or inbox that tickets can be routed to.
 *
 * Design principles:
 *  - teamId on Ticket is nullable; null means "default inbox" — no migration risk.
 *  - color is a hex string used to render team badge pills in the UI.
 *  - Members are agents who belong to the team; determines the agent picker on tickets.
 */
model Team {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  description String?
  color       String       @default("#6366f1")
  email       String?      @unique
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  tickets          Ticket[]
  incidents        Incident[]
  serviceRequests  ServiceRequest[]
  fulfillmentTasks FulfillmentTask[]
  problems         Problem[]
  configItems      ConfigItem[]
  catalogItems     CatalogItem[]     @relation("CatalogItemFulfillmentTeam")
  members          TeamMember[]
  changesCoordinated Change[]        @relation("ChangeCoordinatorGroup")
  teamDashboards     DashboardConfig[]    @relation("DashboardVisibilityTeam")
  scenarioVisibility ScenarioDefinition[] @relation("ScenarioVisibilityTeam")
  savedReports       SavedReport[]        @relation("SavedReportTeam")
  assets             Asset[]
  escalatedTickets   Ticket[]            @relation("EscalatedToTeam")

  routingConfig    TeamRoutingConfig?
  dutyPlans        DutyPlan[]
  dutyPlanRoles    DutyPlanRole[]

  @@map("queue")
}

model TeamMember {
  teamId Int    @map("queueId")
  userId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([teamId, userId])
  @@map("queue_member")
