// ── Assignment & Capacity Routing ─────────────────────────────────────────────

/**
 * AgentCapacityProfile — per-agent routing preferences and capacity settings.
 *
 * Used by the assignment routing service to filter eligible agents before
 * applying the team's routing strategy.
 *
 * skills / languages: free-form string arrays (e.g. ["billing", "enterprise"]).
 * shiftDays: ISO weekday numbers — 1=Mon … 7=Sun. Empty = available all days.
 * weight: used for weighted round-robin (1 = standard, 10 = 10× the share).
 */
model AgentCapacityProfile {
  userId               String   @id @map("user_id")
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  isAvailable          Boolean  @default(true)  @map("is_available")
  maxConcurrentTickets Int      @default(10)    @map("max_concurrent_tickets")
  skills               String[] @default([])
  languages            String[] @default([])
  timezone             String   @default("UTC")
  shiftStart           String?  @map("shift_start")  // "09:00" (local time in agent timezone)
  shiftEnd             String?  @map("shift_end")    // "17:00"
  shiftDays            Int[]    @default([1,2,3,4,5]) @map("shift_days") // 1=Mon…7=Sun
  weight               Int      @default(1)           // 1–10 for weighted round-robin
  notes                String?  // admin notes about this agent's routing preferences
  updatedAt            DateTime @updatedAt @map("updated_at")

  @@index([isAvailable])
  @@map("agent_capacity_profile")
}

/**
 * TeamRoutingConfig — declarative routing strategy for each team/inbox.
 *
 * strategy values:
 *   round_robin   — distribute evenly; ignores load (default)
 *   weighted_rr   — distribute proportionally to agent weight
 *   least_loaded  — assign to agent with fewest open records
 *   skill_based   — rank by skill match score; tie-break by load
 *   manual        — do not auto-assign; only apply team assignment
 *
 * skillMatchMode values:
 *   none          — skip skill filtering entirely
 *   preferred     — prefer agents with matching skills; don't exclude others
 *   required      — only assign to agents who have at least one required skill
 */
model TeamRoutingConfig {
  teamId           Int      @id @map("queue_id")
  team             Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  strategy         String   @default("round_robin") @map("strategy")
  respectCapacity  Boolean  @default(true)  @map("respect_capacity")  // skip agents at maxConcurrentTickets
  respectShifts    Boolean  @default(false) @map("respect_shifts")    // skip off-shift agents
  skillMatchMode   String   @default("none") @map("skill_match_mode") // "none"|"preferred"|"required"
  fallbackAgentId  String?  @map("fallback_agent_id")  // used when no eligible agent found in team
  fallbackTeamId   Int?     @map("fallback_team_id")   // overflow to another team (full team transfer)
  overflowAt       Int?     @map("overflow_at")         // avg open tickets per agent — trigger overflow
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("team_routing_config")
}

/**
 * RoutingDecision — immutable audit log of every assignment routing decision.
 *
 * Written by the routing service on every `assign_smart`, `assign_by_skill`,
 * `assign_round_robin`, and `assign_least_loaded` call.
 */
model RoutingDecision {
  id              Int      @id @default(autoincrement())
  ticketId        Int      @map("ticket_id")
  teamId          Int      @map("team_id")
  strategy        String                          // strategy that was applied
  candidateCount  Int      @map("candidate_count") // agents considered before filtering
  eligibleCount   Int      @map("eligible_count")  // agents after filtering
  selectedAgentId String?  @map("selected_agent_id")
  reason          String                          // human-readable decision rationale
  skillsRequired  String[] @map("skills_required") // skills requested for this routing call
  fallbackUsed    Boolean  @default(false) @map("fallback_used")
  overflowUsed    Boolean  @default(false) @map("overflow_used")
  durationMs      Int      @default(0) @map("duration_ms")
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([ticketId])
  @@index([teamId, createdAt])
  @@index([selectedAgentId])
  @@map("routing_decision")
}

/**
 * SystemSetting — one row per settings section.
 *
 * Storage design:
 *   - section is the primary key ("general", "branding", etc.)
 *   - data is a JSON blob for the entire section's settings
 *   - Zod schemas in core/schemas/settings.ts define shape + defaults
 *   - Missing fields are filled in with defaults at read time (schema.parse)
 *   - updatedById is informational; no FK constraint to keep User model clean
 *
 * To add a new settings section:
 *   1. Add section key to `settingsSections` in core/schemas/settings.ts
 *   2. Define its Zod schema in the same file
 *   3. Add it to `sectionSchemas` map
 *   4. Add UI section form in client/src/pages/settings/sections/
 *   No DB migration needed — new section rows are created on first PUT.
 */
model SystemSetting {
  section     String   @id
  data        Json     @default("{}")
  updatedAt   DateTime @updatedAt
  updatedById String?

  @@map("system_setting")
}

/**
 * DashboardConfig — stores named dashboard configurations for users.
 *
 * Design:
 *   - userId null + isShared = true  → admin-created dashboard visible to everyone
 *   - userId set + isShared = false  → personal user dashboard
 *   - config is a JSON blob validated against DashboardConfigData in core/schemas/dashboard.ts
 *   - UserPreference.defaultDashboard stores the active dashboard id (as string) per user;
 *     "overview" / empty means use the built-in system default.
 *
 * To add new widget types:
 *   1. Add the widget id to WIDGET_IDS in core/schemas/dashboard.ts
 *   2. Add a WIDGET_META entry (label + description)
 *   3. Render the new widget in renderWidget() in HomePage.tsx
 *   No DB migration needed — the JSON blob is schema-less on the DB side.
 */
model DashboardConfig {
  id               Int      @id @default(autoincrement())
  userId           String?  @map("user_id")
  name             String
  description      String?
  isShared         Boolean  @default(false) @map("is_shared")
  /// Team-scoped visibility: visible to all members of this team (but not globally)
  visibilityTeamId Int?     @map("visibility_team_id")
  /// Source dashboard this was cloned from (informational)
  sourceId         Int?     @map("source_id")
  config           Json
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user             User?             @relation(fields: [userId], references: [id], onDelete: Cascade)
  visibilityTeam   Team?             @relation("DashboardVisibilityTeam", fields: [visibilityTeamId], references: [id], onDelete: SetNull)
  source           DashboardConfig?  @relation("DashboardCloneSource", fields: [sourceId], references: [id], onDelete: SetNull)
  clones           DashboardConfig[] @relation("DashboardCloneSource")

  @@index([userId])
  @@index([visibilityTeamId])
  @@map("dashboard_config")
}

/**
 * SavedTicketView — a named, savable ticket list view configuration per user.
 *
 * Design:
 *   - config stores column visibility/order, default sort, and optional filter preset
 *   - isDefault: the user's active column layout (only one per user at a time)
 *   - isShared: admin-created views visible to all users (read-only for non-admins)
 *   - config is validated against SavedViewConfig in core/schemas/ticket-view.ts
 */
model SavedTicketView {
  id        Int      @id @default(autoincrement())
  userId    String   @map("user_id")
  name      String
  emoji     String?
  isDefault Boolean  @default(false) @map("is_default")
