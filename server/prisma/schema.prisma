// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  admin
  supervisor
  agent
  readonly
  customer
}

enum TicketStatus {
  new
  processing
  open
  resolved
  closed
}

enum SenderType {
  agent
  customer
}

enum VirusScanStatus {
  pending
  clean
  infected
  skipped
}

enum TicketCategory {
  general_question
  technical_question
  refund_request
}

enum TicketPriority {
  low
  medium
  high
  urgent
}

enum TicketSeverity {
  sev4
  sev3
  sev2
  sev1
}

enum TicketImpact {
  low
  medium
  high
}

enum TicketUrgency {
  low
  medium
  high
}

enum KbArticleStatus {
  draft
  published
}

enum KbReviewStatus {
  draft
  in_review
  approved
  archived
}

enum KbVisibility {
  public
  internal
}

enum TicketType {
  incident
  service_request
  problem
  change_request
}

enum EscalationReason {
  first_response_sla_breach
  resolution_sla_breach
  urgent_priority
  sev1_severity
  manual
  rule_triggered
}

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean
  image         String?
  role          Role      @default(agent)
  createdAt     DateTime
  updatedAt     DateTime
  deletedAt     DateTime?
  sessions        Session[]
  accounts        Account[]
  assignedTickets     Ticket[]
  replies             Reply[]
  notes               Note[]
  auditEvents         AuditEvent[]
  macros              Macro[]
  kbArticlesAuthored      KbArticle[]        @relation("KbArticleAuthor")
  kbArticlesOwned         KbArticle[]        @relation("KbArticleOwner")
  kbArticlesReviewed      KbArticle[]        @relation("KbArticleReviewer")
  kbArticleVersions       KbArticleVersion[]
  uploadedAttachments Attachment[]
  teamMemberships     TeamMember[]
  preference          UserPreference?
  dashboards          DashboardConfig[]
  savedTicketViews    SavedTicketView[]
  // Incident management relations
  incidentsCommanded    Incident[]          @relation("IncidentCommander")
  incidentsAssigned     Incident[]          @relation("IncidentAssignee")
  incidentsCreated      Incident[]          @relation("IncidentCreatedBy")
  incidentUpdates       IncidentUpdate[]    @relation("IncidentUpdateAuthor")
  incidentEvents        IncidentEvent[]     @relation("IncidentEventActor")
  // Approval engine relations
  approvalRequestsMade  ApprovalRequest[]   @relation("ApprovalRequestedBy")
  approvalStepsAssigned ApprovalStep[]      @relation("ApprovalStepApprover")
  approvalDecisions     ApprovalDecision[]  @relation("ApprovalDecisionBy")
  approvalEvents        ApprovalEvent[]     @relation("ApprovalEventActor")
  // Service Request relations
  requestsSubmitted     ServiceRequest[]    @relation("RequestSubmittedBy")
  requestsAssigned      ServiceRequest[]    @relation("RequestAssignee")
  requestsCreated       ServiceRequest[]    @relation("RequestCreatedBy")
  fulfillmentTasksAssigned FulfillmentTask[] @relation("FulfillmentTaskAssignee")
  fulfillmentTasksCreated  FulfillmentTask[] @relation("FulfillmentTaskCreatedBy")
  requestEvents         RequestEvent[]      @relation("RequestEventActor")
  // Problem management relations
  problemsOwned         Problem[]           @relation("ProblemOwner")
  problemsAssigned      Problem[]           @relation("ProblemAssignee")
  problemNotes          ProblemNote[]       @relation("ProblemNoteAuthor")
  problemIncidentLinks  ProblemIncidentLink[] @relation("ProblemLinkLinkedBy")
  problemEvents         ProblemEvent[]      @relation("ProblemEventActor")
  // CMDB relations
  cisOwned              ConfigItem[]        @relation("CiOwner")
  cisCreated            ConfigItem[]        @relation("CiCreatedBy")
  ciEvents              CiEvent[]           @relation("CiEventActor")
  // Catalog relations
  catalogItemsCreated   CatalogItem[]       @relation("CatalogItemCreatedBy")
  // Notification relations
  notifications         Notification[]      @relation("NotificationRecipient")
  // Organization account management
  accountManagerFor     Organization[]      @relation("OrgAccountManager")

  @@map("user")
}

model UserPreference {
  userId            String   @id
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Profile extras
  jobTitle          String?
  phone             String?
  // Locale
  language          String   @default("en")
  timezone          String   @default("UTC")
  dateFormat        String   @default("MMM d, yyyy")
  timeFormat        String   @default("12h")
  // UI
  theme             String   @default("system")
  sidebarCollapsed  Boolean  @default(false)
  defaultDashboard  String   @default("overview")
  ticketListDensity String   @default("comfortable")
  // Future: notificationPrefs Json?  signatureHtml String?
  updatedAt         DateTime @updatedAt

  @@map("user_preference")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
}

model Organization {
  id               Int        @id @default(autoincrement())
  name             String
  domain           String?    @unique
  notes            String?
  // ── Enrichment ───────────────────────────────────────────────────────────
  website          String?    @map("website")
  industry         String?    @map("industry")
  employeeCount    Int?       @map("employee_count")
  country          String?    @map("country")
  address          String?    @map("address")
  // Support configuration
  supportTier      String     @default("standard") @map("support_tier")
  accountManagerId String?    @map("account_manager_id")
  accountManager   User?      @relation("OrgAccountManager", fields: [accountManagerId], references: [id])
  isActive         Boolean    @default(true) @map("is_active")
  // ─────────────────────────────────────────────────────────────────────────
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  customers  Customer[]
  entitlements ServiceEntitlement[]

  @@index([supportTier])
  @@index([isActive])
  @@map("organization")
}

model Customer {
  id             Int           @id @default(autoincrement())
  email          String        @unique
  name           String
  organizationId Int?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  notes          String?
  // ── Enrichment ───────────────────────────────────────────────────────────
  phone            String?  @map("phone")
  jobTitle         String?  @map("job_title")
  timezone         String   @default("UTC") @map("timezone")
  language         String   @default("en") @map("language")
  preferredChannel String?  @map("preferred_channel")
  isVip            Boolean  @default(false) @map("is_vip")
  supportTier      String   @default("standard") @map("support_tier")
  avatarUrl        String?  @map("avatar_url")
  // ─────────────────────────────────────────────────────────────────────────
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  tickets          Ticket[]
  serviceRequests  ServiceRequest[]

  @@index([isVip])
  @@index([supportTier])
  @@index([organizationId])
  @@map("customer")
}

/**
 * ServiceEntitlement — records the support contract or service tier for an organization.
 * Placeholder model: gates, limits, and SLA policies are wired up as entitlements mature.
 *
 * tier: "free" | "standard" | "premium" | "enterprise"
 * slaPolicy: name of an SLA policy to apply to tickets from this org
 */
model ServiceEntitlement {
  id             Int          @id @default(autoincrement())
  organizationId Int          @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tier           String       @default("standard") @map("tier")
  maxUsers       Int?         @map("max_users")
  slaPolicy      String?      @map("sla_policy")
  features       String[]     @map("features")
  startsAt       DateTime?    @map("starts_at")
  expiresAt      DateTime?    @map("expires_at")
  isActive       Boolean      @default(true) @map("is_active")
  notes          String?      @map("notes")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@index([organizationId, isActive])
  @@map("service_entitlement")
}

model TicketCounter {
  series    String  @map("series")
  periodKey String  @default("") @map("period_key")
  lastValue Int     @default(0)  @map("last_value")

  @@id([series, periodKey])
  @@map("ticket_counter")
}

model Ticket {
  id           Int             @id @default(autoincrement())
  /// Immutable human-readable display ID. Format: {PREFIX}{dateSegment?}{zeroPaddedSeq}.
  /// Generated at creation time from ticket_counter. Never changes after assignment.
  ticketNumber String          @unique @map("ticket_number")
  subject      String
  body         String
  bodyHtml     String?
  status       TicketStatus    @default(new)
  ticketType   TicketType?
  affectedSystem String?
  category     TicketCategory?
  priority     TicketPriority?
  severity     TicketSeverity?
  impact       TicketImpact?
  urgency      TicketUrgency?
  senderName   String
  senderEmail  String
  // Customer entity — resolved from senderEmail at ticket-creation time.
  // Kept nullable so that legacy tickets (pre-migration) are not broken.
  customerId   Int?
  customer     Customer?       @relation(fields: [customerId], references: [id])
  assignedToId String?
  assignedTo   User?           @relation(fields: [assignedToId], references: [id])
  // Team — which support team/inbox this ticket belongs to. Null = default inbox.
  // @map keeps the DB column name (queueId) while TypeScript uses teamId.
  teamId       Int?            @map("queueId")
  team         Team?           @relation(fields: [teamId], references: [id], onDelete: SetNull)
  // Email threading: Message-ID header from the original inbound email.
  // Used to set In-Reply-To / References when sending agent replies.
  emailMessageId String?
  // Channel that created this ticket: "email", "portal", "agent", or null for legacy rows.
  source         String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  replies      Reply[]
  attachments  Attachment[]

  // SLA: deadlines are calculated from priority at ticket creation.
  // Recalculated when priority changes. Null = no SLA target set yet.
  firstResponseDueAt  DateTime?
  resolutionDueAt     DateTime?

  // SLA: actuals — stamped when the milestone is reached.
  firstRespondedAt    DateTime?
  resolvedAt          DateTime?

  // Persistent breach flag. Once true, stays true for historical reporting
  // even if the ticket is later resolved.
  slaBreached         Boolean   @default(false)

  // Escalation — isEscalated is a live flag; escalationEvents is the full audit trail.
  isEscalated         Boolean            @default(false)
  escalatedAt         DateTime?
  // First reason that triggered escalation (subsequent reasons go in escalationEvents only)
  escalationReason    EscalationReason?
  escalationEvents    EscalationEvent[]

  notes               Note[]
  auditEvents         AuditEvent[]
  csatRating          CsatRating?
  ciLinks             TicketCiLink[]

  @@map("ticket")
}

model EscalationEvent {
  id        Int              @id @default(autoincrement())
  ticketId  Int
  ticket    Ticket           @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  reason    EscalationReason
  createdAt DateTime         @default(now())

  @@map("escalation_event")
}

model Reply {
  id             Int          @id @default(autoincrement())
  body           String
  bodyHtml       String?
  senderType     SenderType
  ticketId       Int
  ticket         Ticket       @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId         String?
  user           User?        @relation(fields: [userId], references: [id])
  // Email threading: Message-ID for this specific reply (inbound from header, outbound generated).
  emailMessageId String?
  // ── Channel metadata ────────────────────────────────────────────────────
  // channel: the intake or outbound channel for this message.
  // Values: "email" | "portal" | "api" | "chat" | "whatsapp" | "slack_teams" | "voice" | "social"
  // Null on legacy rows pre-omnichannel.
  channel        String?      @map("channel")
  // channelMeta: channel-specific structured data (e.g. WhatsApp waId, email Message-ID chain).
  // Kept as untyped JSON so channel adapters can store what they need without migrations.
  channelMeta    Json?        @map("channel_meta")
  // ────────────────────────────────────────────────────────────────────────
  createdAt      DateTime     @default(now())
  attachments    Attachment[]

  @@index([channel])
  @@map("reply")
}

/**
 * Attachment — file attached to a ticket's original message or a specific reply.
 *
 * Storage assumptions:
 *   - Files are stored on disk in UPLOAD_DIR (env var, default ./uploads).
 *   - storageKey is a UUID-based filename — original names are never used as paths.
 *   - To swap to object storage (S3 / R2 / GCS), replace server/src/lib/storage.ts only.
 *   - Notes intentionally have no Attachment relation — internal notes must never
 *     include external file transfers.
 *
 * Scoping:
 *   - ticketId is always set; provides CASCADE delete when a ticket is removed.
 *   - replyId is null for ticket-level attachments (original inbound email).
 *   - replyId is set for reply-level attachments (inbound email replies or agent replies).
 */
model Attachment {
  id              Int             @id @default(autoincrement())
  filename        String
  mimeType        String
  size            Int
  storageKey      String          @unique
  /// Which backend holds this file: "local", "s3", "gcs", "r2".
  /// Used to route load/remove calls to the correct provider on retrieval.
  storageProvider String          @default("local")
  /// SHA-256 hex digest of the raw file bytes. Null for legacy uploads
  /// created before this column was added.
  checksum        String?
  /// Result of the virus scan. "skipped" means no scanner was configured.
  /// Block downloads when status is "infected" or optionally when "pending".
  virusScanStatus VirusScanStatus @default(skipped)
  ticketId        Int
  ticket          Ticket          @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  replyId         Int?
  reply           Reply?          @relation(fields: [replyId], references: [id], onDelete: SetNull)
  uploadedById    String?
  uploadedBy      User?           @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  createdAt       DateTime        @default(now())

  @@index([ticketId])
  @@index([replyId])
  @@index([virusScanStatus])
  @@map("attachment")
}

model Note {
  id               Int      @id @default(autoincrement())
  body             String
  bodyHtml         String?
  isPinned         Boolean  @default(false)
  ticketId         Int
  ticket           Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  // authorId is nullable to allow system/workflow-generated notes (no human actor)
  authorId         String?
  author           User?    @relation(fields: [authorId], references: [id])
  // Future: store @mentioned agent IDs for notification routing
  mentionedUserIds String[] @default([])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("note")
}

/**
 * AuditEvent — append-only record of every significant action on a ticket.
 *
 * Design principles:
 *  - action is a dot-namespaced string constant ("ticket.created", "reply.created", etc.)
 *    — easy to filter, index, and extend without schema changes.
 *  - actorId null means the action was performed by the system / background job.
 *  - meta is a free-form JSON object. Convention: include "from"/"to" for field
 *    changes, "reason" for escalations, "id" for related record references.
 *    Never store secrets, passwords, or auth tokens in meta.
 *  - Cascades on ticket delete so audit history is removed with the ticket.
 */
/**
 * Macro — a saved reply template with optional variable placeholders.
 *
 * Supported placeholders (resolved client-side at insertion time):
 *   {{customer_name}}   first name of the ticket sender
 *   {{customer_email}}  sender email address
 *   {{ticket_id}}       numeric ticket ID
 *   {{agent_name}}      name of the currently logged-in agent
 */
model Macro {
  id          Int             @id @default(autoincrement())
  title       String
  body        String
  category    TicketCategory?
  isActive    Boolean         @default(true)
  createdById String
  createdBy   User            @relation(fields: [createdById], references: [id])
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@map("macro")
}

model AuditEvent {
  id        Int      @id @default(autoincrement())
  ticketId  Int
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  actorId   String?
  actor     User?    @relation(fields: [actorId], references: [id])
  action    String
  meta      Json     @default("{}")
  createdAt DateTime @default(now())

  @@index([ticketId, createdAt])
  @@map("audit_event")
}

/**
 * KbCategory — groups knowledge base articles into logical sections.
 * Position controls display order in the help center.
 */
/**
 * CsatRating — one record per resolved/closed ticket, submitted by the customer.
 *
 * rating: 1 (very unhappy) – 5 (very happy)
 * comment: optional free-text feedback
 * Uniqueness on ticketId ensures one submission per ticket.
 */
model CsatRating {
  id          Int      @id @default(autoincrement())
  ticketId    Int      @unique
  ticket      Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  rating      Int
  comment     String?
  submittedAt DateTime @default(now())

  @@map("csat_rating")
}

model KbCategory {
  id          Int         @id @default(autoincrement())
  name        String
  slug        String      @unique
  description String?
  position    Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  articles    KbArticle[]

  @@map("kb_category")
}

/**
 * KbArticle — a help center article authored in Markdown.
 *
 * status:
 *   draft      — only visible to agents/admins, never served publicly
 *   published  — visible in the public help center
 *
 * slug is auto-derived from title at creation and used as the public URL key.
 * viewCount is incremented on each public read (for popularity ordering).
 */
model KbArticle {
  id              Int              @id @default(autoincrement())
  title           String
  slug            String           @unique
  body            String
  status          KbArticleStatus  @default(draft)
  reviewStatus    KbReviewStatus   @default(draft)
  visibility      KbVisibility     @default(public)
  categoryId      Int?
  category        KbCategory?      @relation(fields: [categoryId], references: [id])
  authorId        String
  author          User             @relation("KbArticleAuthor", fields: [authorId], references: [id])
  ownerId         String?
  owner           User?            @relation("KbArticleOwner", fields: [ownerId], references: [id])
  reviewedById    String?
  reviewedBy      User?            @relation("KbArticleReviewer", fields: [reviewedById], references: [id])
  publishedAt     DateTime?
  reviewedAt      DateTime?
  viewCount       Int              @default(0)
  helpfulCount    Int              @default(0)
  notHelpfulCount Int              @default(0)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  versions        KbArticleVersion[]
  feedback        KbArticleFeedback[]

  @@index([status])
  @@index([reviewStatus])
  @@index([categoryId])
  @@map("kb_article")
}

/**
 * KbArticleVersion — immutable snapshot of an article at a point in time.
 * Created automatically whenever a published article is updated.
 */
model KbArticleVersion {
  id            Int       @id @default(autoincrement())
  articleId     Int
  article       KbArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  versionNumber Int
  title         String
  body          String
  changeNote    String?
  createdById   String
  createdBy     User      @relation(fields: [createdById], references: [id])
  createdAt     DateTime  @default(now())

  @@unique([articleId, versionNumber])
  @@index([articleId])
  @@map("kb_article_version")
}

/**
 * KbArticleFeedback — helpfulness vote from a help-center visitor.
 * sessionId is optional (anonymous tracking).
 */
model KbArticleFeedback {
  id          Int       @id @default(autoincrement())
  articleId   Int
  article     KbArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  helpful     Boolean
  comment     String?
  sessionId   String?
  submittedAt DateTime  @default(now())

  @@index([articleId])
  @@map("kb_article_feedback")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

/**
 * Team — a named support team or inbox that tickets can be routed to.
 *
 * Design principles:
 *  - teamId on Ticket is nullable; null means "default inbox" — no migration risk.
 *  - color is a hex string used to render team badge pills in the UI.
 *  - Members are agents who belong to the team; determines the agent picker on tickets.
 */
model Team {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  description String?
  color       String       @default("#6366f1")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  tickets          Ticket[]
  incidents        Incident[]
  serviceRequests  ServiceRequest[]
  fulfillmentTasks FulfillmentTask[]
  problems         Problem[]
  configItems      ConfigItem[]
  catalogItems     CatalogItem[]     @relation("CatalogItemFulfillmentTeam")
  members          TeamMember[]

  @@map("queue")
}

model TeamMember {
  teamId Int    @map("queueId")
  userId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([teamId, userId])
  @@map("queue_member")
}

/**
 * SystemSetting — one row per settings section.
 *
 * Storage design:
 *   - section is the primary key ("general", "branding", etc.)
 *   - data is a JSON blob for the entire section's settings
 *   - Zod schemas in core/schemas/settings.ts define shape + defaults
 *   - Missing fields are filled in with defaults at read time (schema.parse)
 *   - updatedById is informational; no FK constraint to keep User model clean
 *
 * To add a new settings section:
 *   1. Add section key to `settingsSections` in core/schemas/settings.ts
 *   2. Define its Zod schema in the same file
 *   3. Add it to `sectionSchemas` map
 *   4. Add UI section form in client/src/pages/settings/sections/
 *   No DB migration needed — new section rows are created on first PUT.
 */
model SystemSetting {
  section     String   @id
  data        Json     @default("{}")
  updatedAt   DateTime @updatedAt
  updatedById String?

  @@map("system_setting")
}

/**
 * DashboardConfig — stores named dashboard configurations for users.
 *
 * Design:
 *   - userId null + isShared = true  → admin-created dashboard visible to everyone
 *   - userId set + isShared = false  → personal user dashboard
 *   - config is a JSON blob validated against DashboardConfigData in core/schemas/dashboard.ts
 *   - UserPreference.defaultDashboard stores the active dashboard id (as string) per user;
 *     "overview" / empty means use the built-in system default.
 *
 * To add new widget types:
 *   1. Add the widget id to WIDGET_IDS in core/schemas/dashboard.ts
 *   2. Add a WIDGET_META entry (label + description)
 *   3. Render the new widget in renderWidget() in HomePage.tsx
 *   No DB migration needed — the JSON blob is schema-less on the DB side.
 */
model DashboardConfig {
  id        Int      @id @default(autoincrement())
  userId    String?  @map("user_id")
  name      String
  isShared  Boolean  @default(false) @map("is_shared")
  config    Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("dashboard_config")
}

/**
 * SavedTicketView — a named, savable ticket list view configuration per user.
 *
 * Design:
 *   - config stores column visibility/order, default sort, and optional filter preset
 *   - isDefault: the user's active column layout (only one per user at a time)
 *   - isShared: admin-created views visible to all users (read-only for non-admins)
 *   - config is validated against SavedViewConfig in core/schemas/ticket-view.ts
 */
model SavedTicketView {
  id        Int      @id @default(autoincrement())
  userId    String   @map("user_id")
  name      String
  emoji     String?
  isDefault Boolean  @default(false) @map("is_default")
  isShared  Boolean  @default(false) @map("is_shared")
  config    Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "saved_ticket_view_user_id_idx")
  @@index([isShared], map: "saved_ticket_view_is_shared_idx")
  @@map("saved_ticket_view")
}

// ── Incident Management ───────────────────────────────────────────────────────

/**
 * ITIL priority classification P1 (critical) → P4 (low).
 * Drives SLA targets and escalation thresholds.
 */
enum IncidentPriority {
  p1
  p2
  p3
  p4
}

/**
 * ITIL-aligned incident lifecycle.
 *
 * new           → acknowledged  (commander picks it up)
 * acknowledged  → in_progress   (active investigation underway)
 * in_progress   → resolved      (root cause mitigated, monitoring phase)
 * resolved      → closed        (post-incident review complete, ticket closed)
 *
 * Any non-closed status can be force-closed by admin.
 */
enum IncidentStatus {
  new
  acknowledged
  in_progress
  resolved
  closed
}

enum IncidentUpdateType {
  /// General status broadcast to stakeholders
  update
  /// Temporary fix that reduces impact while root cause is investigated
  workaround
  /// Permanent fix applied — precedes resolution status change
  resolution
  /// Severity increased; war-room participation required
  escalation
  /// Impact cleared; monitoring period begun
  all_clear
}

/**
 * Incident — a first-class ITIL record separate from the ticket system.
 *
 * Design principles:
 *  - No senderName/senderEmail — incidents are internal records, not customer support items.
 *  - commanderId: the named person responsible for driving resolution (IC role).
 *  - isMajor: triggers war-room mode; affects stakeholder notifications.
 *  - affectedUserCount: used for impact scoring and escalation thresholds.
 *  - SLA: responseDeadline / resolutionDeadline computed from priority at creation,
 *    using ITIL P1-P4 targets (not the ticket SLA policy).
 *  - incidentNumber: generated via the ticket_counter table with series "incident"
 *    so it shares the INC-NNNN namespace with ticket-type=incident.
 */
model Incident {
  id                Int             @id @default(autoincrement())
  incidentNumber    String          @unique @map("incident_number")
  title             String
  description       String?
  status            IncidentStatus  @default(new)
  priority          IncidentPriority
  isMajor           Boolean         @default(false) @map("is_major")
  affectedSystem    String?         @map("affected_system")
  affectedUserCount Int?            @map("affected_user_count")

  // Commander — the individual accountable for driving the incident to resolution
  commanderId  String?  @map("commander_id")
  commander    User?    @relation("IncidentCommander", fields: [commanderId], references: [id])

  // Primary assignee — the agent actively working the incident
  assignedToId String?  @map("assigned_to_id")
  assignedTo   User?    @relation("IncidentAssignee", fields: [assignedToId], references: [id])

  // Routing — which team is handling this incident
  teamId  Int?   @map("team_id")
  team    Team?  @relation(fields: [teamId], references: [id], onDelete: SetNull)

  // SLA tracking
  responseDeadline  DateTime? @map("response_deadline")
  resolutionDeadline DateTime? @map("resolution_deadline")
  acknowledgedAt    DateTime? @map("acknowledged_at")
  respondedAt       DateTime? @map("responded_at")
  resolvedAt        DateTime? @map("resolved_at")
  closedAt          DateTime? @map("closed_at")
  slaBreached       Boolean   @default(false) @map("sla_breached")

  createdById  String?  @map("created_by_id")
  createdBy    User?    @relation("IncidentCreatedBy", fields: [createdById], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  updates          IncidentUpdate[]
  events           IncidentEvent[]
  problemLinks     ProblemIncidentLink[]
  ciLinks          IncidentCiLink[]

  @@index([status])
  @@index([priority])
  @@index([isMajor])
  @@index([commanderId])
  @@index([assignedToId])
  @@map("incident")
}

/**
 * IncidentUpdate — a timestamped entry on the incident timeline.
 *
 * Used by the incident team to broadcast progress, workarounds, and
 * resolutions to stakeholders. Rendered in the incident detail timeline.
 * Intentionally simple — no threading, no replies.
 */
model IncidentUpdate {
  id         Int                @id @default(autoincrement())
  incidentId Int                @map("incident_id")
  incident   Incident           @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  updateType IncidentUpdateType @default(update) @map("update_type")
  body       String
  authorId   String?            @map("author_id")
  author     User?              @relation("IncidentUpdateAuthor", fields: [authorId], references: [id])
  createdAt  DateTime           @default(now())

  @@index([incidentId, createdAt])
  @@map("incident_update")
}

/**
 * IncidentEvent — append-only audit trail for every state transition.
 *
 * Separate from ticket AuditEvent (which is ticket-scoped).
 * action naming: "incident.<verb>" e.g. incident.created, incident.acknowledged.
 */
model IncidentEvent {
  id         Int      @id @default(autoincrement())
  incidentId Int      @map("incident_id")
  incident   Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  actorId    String?  @map("actor_id")
  actor      User?    @relation("IncidentEventActor", fields: [actorId], references: [id])
  action     String
  meta       Json     @default("{}")
  createdAt  DateTime @default(now())

  @@index([incidentId, createdAt])
  @@map("incident_event")
}

// ── Approval Engine ───────────────────────────────────────────────────────────

/**
 * Overall lifecycle state of an ApprovalRequest.
 *
 * pending    — awaiting one or more decisions
 * approved   — all required approvals received
 * rejected   — at least one step was rejected (and mode requires all)
 * cancelled  — explicitly cancelled before completion
 * expired    — passed expiresAt without a final decision
 */
enum ApprovalStatus {
  pending
  approved
  rejected
  cancelled
  expired
}

/**
 * Per-step decision state (mirrors ApprovalStatus minus cancelled/expired).
 * skipped = step was bypassed (e.g. request cancelled before this step activated)
 */
enum ApprovalStepStatus {
  pending
  approved
  rejected
  skipped
}

/**
 * ApprovalRequest — the top-level governed action awaiting sign-off.
 *
 * Design principles:
 *  - subjectType + subjectId make this generic: any future module (changes,
 *    service requests, access requests, policy exceptions) attaches by setting
 *    these two fields — no schema change needed.
 *  - approvalMode controls how steps are evaluated:
 *      "any"  — first approval from any step resolves the request as approved
 *      "all"  — every step must approve, in stepOrder sequence
 *  - requiredCount is used with "any" mode to require N of M approvals.
 *  - expiresAt is optional; a background job can flip status to "expired".
 *  - requestedById null = system-initiated approval (e.g. auto-triggered by workflow).
 */
model ApprovalRequest {
  id             Int            @id @default(autoincrement())
  /// Human-readable subject type: "change_request" | "service_request" | "access_request" | "policy_exception"
  subjectType    String         @map("subject_type")
  /// ID of the governed entity in the source table (stored as string for flexibility)
  subjectId      String         @map("subject_id")
  title          String
  description    String?
  status         ApprovalStatus @default(pending)
  /// "any" = any one approval suffices | "all" = all steps must approve in order
  approvalMode   String         @default("all") @map("approval_mode")
  /// For "any" mode: how many approvals are needed (default 1)
  requiredCount  Int            @default(1) @map("required_count")
  requestedById  String?        @map("requested_by_id")
  requestedBy    User?          @relation("ApprovalRequestedBy", fields: [requestedById], references: [id])
  expiresAt      DateTime?
  resolvedAt     DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  steps   ApprovalStep[]
  events  ApprovalEvent[]

  @@index([subjectType, subjectId])
  @@index([status])
  @@map("approval_request")
}

/**
 * ApprovalStep — one approver assignment within a request.
 *
 * Multiple steps at the same stepOrder run in parallel.
 * Steps at higher stepOrder only activate once all lower-order steps complete.
 *
 * approverId must be a valid User.id. Future: extend to team/role via
 * approverType field ("user" | "team" | "role").
 */
model ApprovalStep {
  id                Int                @id @default(autoincrement())
  approvalRequestId Int                @map("approval_request_id")
  approvalRequest   ApprovalRequest    @relation(fields: [approvalRequestId], references: [id], onDelete: Cascade)
  stepOrder         Int                @default(1) @map("step_order")
  approverId        String             @map("approver_id")
  approver          User               @relation("ApprovalStepApprover", fields: [approverId], references: [id])
  status            ApprovalStepStatus @default(pending)
  /// true when this step is currently awaiting the approver's decision
  isActive          Boolean            @default(false) @map("is_active")
  dueAt             DateTime?
  createdAt         DateTime           @default(now())

  decisions ApprovalDecision[]

  @@index([approvalRequestId, stepOrder])
  @@index([approverId, status])
  @@map("approval_step")
}

/**
 * ApprovalDecision — the recorded vote for a step.
 *
 * One decision per step. The decidedById must match the step's approverId
 * (enforced in the approval engine, not at DB level for flexibility).
 */
model ApprovalDecision {
  id             Int          @id @default(autoincrement())
  stepId         Int          @unique @map("step_id")
  step           ApprovalStep @relation(fields: [stepId], references: [id], onDelete: Cascade)
  decidedById    String       @map("decided_by_id")
  decidedBy      User         @relation("ApprovalDecisionBy", fields: [decidedById], references: [id])
  /// "approved" | "rejected"
  decision       String
  comment        String?
  decidedAt      DateTime     @default(now())

  @@map("approval_decision")
}

/**
 * ApprovalEvent — append-only audit trail for every approval action.
 *
 * Intentionally separate from AuditEvent (which is ticket-scoped).
 * action naming: "approval.<verb>" — e.g. approval.created, approval.approved.
 */
model ApprovalEvent {
  id                Int             @id @default(autoincrement())
  approvalRequestId Int             @map("approval_request_id")
  approvalRequest   ApprovalRequest @relation(fields: [approvalRequestId], references: [id], onDelete: Cascade)
  actorId           String?         @map("actor_id")
  actor             User?           @relation("ApprovalEventActor", fields: [actorId], references: [id])
  action            String
  meta              Json            @default("{}")
  createdAt         DateTime        @default(now())

  @@index([approvalRequestId, createdAt])
  @@map("approval_event")
}

// ── Workflow Engine ────────────────────────────────────────────────────────────

enum WorkflowExecutionStatus {
  running
  completed
  failed
  skipped
}

/**
 * WorkflowDefinition — a DB-stored automation rule.
 *
 * Design principles:
 *  - triggers / conditions / actions are JSON blobs — same shapes as the
 *    existing file-based AutomationRule in server/src/lib/automation/types.ts.
 *    This makes migration from RULES[] straightforward: dump each rule into a row.
 *  - isEnabled is a soft on/off switch (no delete needed to pause a workflow).
 *  - migratedFromRuleId links a row to its legacy RULES[] counterpart so the
 *    bridge period is tracked and the old rule can be removed once confirmed stable.
 *  - version is a monotonic integer bumped on every edit (optimistic locking hint).
 *  - createdById / updatedById are nullable — null means seeded or system-generated.
 */
model WorkflowDefinition {
  id                 Int      @id @default(autoincrement())
  name               String
  description        String?
  isEnabled          Boolean  @default(true)  @map("is_enabled")
  /// JSON array of trigger strings — e.g. ["ticket.created", "ticket.updated"]
  triggers           Json
  /// JSON tree of conditions (same Condition union as automation/types.ts)
  conditions         Json     @default("{}")
  /// JSON array of actions (WorkflowAction union — superset of Action)
  actions            Json
  /// Tracks which legacy RULES[] id was migrated into this row (if any)
  migratedFromRuleId String?  @map("migrated_from_rule_id")
  version            Int      @default(1)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  createdById        String?
  updatedById        String?

  executions WorkflowExecution[]

  @@index([isEnabled])
  @@map("workflow_definition")
}

/**
 * WorkflowExecution — one record per workflow run against a specific ticket.
 *
 * status:
 *   running   — execution started but not yet complete (should be short-lived)
 *   completed — all actions evaluated (some may have been skipped)
 *   failed    — unhandled error during execution
 *   skipped   — conditions did not match; no actions were attempted
 */
model WorkflowExecution {
  id                   Int                     @id @default(autoincrement())
  workflowDefinitionId Int
  workflowDefinition   WorkflowDefinition      @relation(fields: [workflowDefinitionId], references: [id], onDelete: Cascade)
  ticketId             Int
  trigger              String
  status               WorkflowExecutionStatus @default(running)
  errorMessage         String?
  startedAt            DateTime                @default(now())
  completedAt          DateTime?

  steps WorkflowExecutionStep[]

  @@index([workflowDefinitionId])
  @@index([ticketId])
  @@map("workflow_execution")
}

/**
 * WorkflowExecutionStep — one record per action within a workflow execution.
 *
 * applied:      true when the action made a real DB change.
 * skippedReason: non-null when applied=false and the action was intentionally no-op'd
 *                (e.g. "already_assigned", "field_unchanged").
 * errorMessage: non-null when the action threw an unexpected error.
 */
model WorkflowExecutionStep {
  id                  Int               @id @default(autoincrement())
  workflowExecutionId Int
  workflowExecution   WorkflowExecution @relation(fields: [workflowExecutionId], references: [id], onDelete: Cascade)
  actionType          String
  applied             Boolean           @default(false)
  skippedReason       String?
  errorMessage        String?
  createdAt           DateTime          @default(now())

  @@index([workflowExecutionId])
  @@map("workflow_execution_step")
}

// ── Service Request Management ─────────────────────────────────────────────────

/**
 * RequestStatus enum — mirrors core/constants/request-status.ts.
 *
 * draft            — saved but not yet submitted
 * submitted        — requester submitted; awaiting triage
 * pending_approval — approval workflow in progress
 * approved         — approval passed or not required; ready to fulfill
 * in_fulfillment   — fulfillment tasks are being worked
 * fulfilled        — all tasks complete; awaiting formal close
 * closed           — terminal: post-fulfillment sign-off done
 * rejected         — terminal: approval rejected or admin declined
 * cancelled        — terminal: withdrawn before completion
 */
enum RequestStatus {
  draft
  submitted
  pending_approval
  approved
  in_fulfillment
  fulfilled
  closed
  rejected
  cancelled
}

/**
 * FulfillmentTaskStatus enum — mirrors core/constants/fulfillment-task-status.ts.
 */
enum FulfillmentTaskStatus {
  pending
  in_progress
  completed
  cancelled
}

/**
 * ServiceRequest — a first-class ITSM service request record.
 *
 * Design principles:
 *  - Separate from Ticket: no senderName/senderEmail email-threading;
 *    requests are always created deliberately (agent or portal).
 *  - Dual requester model: requesterId (agent/staff) XOR requesterCustomerId (portal customer).
 *    requesterName / requesterEmail are denormalized for fast list rendering.
 *  - formData stores submitted variables as a JSON bag so catalog items can
 *    inject their own fields without schema changes.
 *  - catalogItemId is a nullable FK placeholder — wired to CatalogItem once that module
 *    is built. catalogItemName is a snapshot so the display survives catalog edits.
 *  - approvalRequestId links to the ApprovalRequest created when requiresApproval=true.
 *  - slaDueAt / slaBreached are SLA placeholders — a real OLA/SLA policy engine
 *    will populate these; they are stored now so the column exists when needed.
 *  - requestNumber is generated via ticket_counter series "request" → REQ-NNNN format.
 */
model ServiceRequest {
  id            Int           @id @default(autoincrement())
  requestNumber String        @unique @map("request_number")
  title         String
  description   String?
  status        RequestStatus @default(submitted)
  priority      TicketPriority @default(medium)

  // Approval integration
  approvalStatus    String    @default("not_required") @map("approval_status")
  approvalRequestId Int?      @map("approval_request_id")

  // Requester — exactly one of these is set (agent or customer)
  requesterId         String?   @map("requester_id")
  requester           User?     @relation("RequestSubmittedBy", fields: [requesterId], references: [id])
  requesterCustomerId Int?      @map("requester_customer_id")
  requesterCustomer   Customer? @relation(fields: [requesterCustomerId], references: [id])
  /// Denormalized for fast list rendering — always set at creation.
  requesterName  String        @map("requester_name")
  requesterEmail String        @map("requester_email")

  // Fulfillment assignment
  assignedToId String? @map("assigned_to_id")
  assignedTo   User?   @relation("RequestAssignee", fields: [assignedToId], references: [id])
  teamId       Int?    @map("team_id")
  team         Team?   @relation(fields: [teamId], references: [id], onDelete: SetNull)

  // Catalog item — FK wired to CatalogItem; snapshot name survives catalog edits
  catalogItemId   Int?         @map("catalog_item_id")
  catalogItem     CatalogItem? @relation(fields: [catalogItemId], references: [id], onDelete: SetNull)
  catalogItemName String?      @map("catalog_item_name")

  // Submitted form variables
  formData Json @default("{}") @map("form_data")

  // SLA placeholder — populated by OLA/SLA engine when configured
  dueDate    DateTime? @map("due_date")
  slaDueAt   DateTime? @map("sla_due_at")
  slaBreached Boolean  @default(false) @map("sla_breached")

  // Lifecycle timestamps
  resolvedAt  DateTime? @map("resolved_at")
  closedAt    DateTime? @map("closed_at")
  cancelledAt DateTime? @map("cancelled_at")

  createdById String?   @map("created_by_id")
  createdBy   User?     @relation("RequestCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  items  RequestItem[]
  tasks  FulfillmentTask[]
  events RequestEvent[]

  @@index([status])
  @@index([priority])
  @@index([requesterId])
  @@index([requesterCustomerId])
  @@index([assignedToId])
  @@index([teamId])
  @@map("service_request")
}

/**
 * RequestItem — one line-item within a ServiceRequest.
 *
 * A request may contain multiple items (e.g. "2× MacBook Pro" + "Docking Station").
 * Each item can track its own fulfillment status independently.
 * catalogItemId is a nullable FK placeholder for the future catalog module.
 */
model RequestItem {
  id            Int            @id @default(autoincrement())
  requestId     Int            @map("request_id")
  request       ServiceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  name          String
  description   String?
  quantity      Int            @default(1)
  unit          String?
  /// Per-item form data (catalog-item-specific fields)
  formData      Json           @default("{}") @map("form_data")
  /// FK placeholder — wired to CatalogItem table once that module is built
  catalogItemId Int?           @map("catalog_item_id")
  status        FulfillmentTaskStatus @default(pending)
  fulfilledAt   DateTime?      @map("fulfilled_at")
  createdAt     DateTime       @default(now())

  @@index([requestId])
  @@map("request_item")
}

/**
 * FulfillmentTask — an actionable work item scoped to a ServiceRequest.
 *
 * Tasks represent discrete steps required to fulfill the request
 * (e.g. "Provision laptop", "Create AD account", "Ship hardware").
 * They are ordered by `position` for display in the task checklist.
 */
model FulfillmentTask {
  id          Int                   @id @default(autoincrement())
  requestId   Int                   @map("request_id")
  request     ServiceRequest        @relation(fields: [requestId], references: [id], onDelete: Cascade)
  title       String
  description String?
  status      FulfillmentTaskStatus @default(pending)
  position    Int                   @default(0)

  assignedToId String? @map("assigned_to_id")
  assignedTo   User?   @relation("FulfillmentTaskAssignee", fields: [assignedToId], references: [id])
  teamId       Int?    @map("team_id")
  team         Team?   @relation(fields: [teamId], references: [id], onDelete: SetNull)

  dueAt       DateTime? @map("due_at")
  completedAt DateTime? @map("completed_at")

  createdById String?   @map("created_by_id")
  createdBy   User?     @relation("FulfillmentTaskCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([requestId, position])
  @@index([assignedToId, status])
  @@map("fulfillment_task")
}

/**
 * RequestEvent — append-only audit trail for every state transition and action
 * on a ServiceRequest.
 *
 * Separate from AuditEvent (which is ticket-scoped).
 * action naming convention: "request.<verb>" — e.g. "request.created", "request.approved".
 */
model RequestEvent {
  id        Int            @id @default(autoincrement())
  requestId Int            @map("request_id")
  request   ServiceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  actorId   String?        @map("actor_id")
  actor     User?          @relation("RequestEventActor", fields: [actorId], references: [id])
  action    String
  meta      Json           @default("{}")
  createdAt DateTime       @default(now())

  @@index([requestId, createdAt])
  @@map("request_event")
}

// ── Problem Management ─────────────────────────────────────────────────────────

/**
 * ProblemStatus enum — mirrors core/constants/problem-status.ts.
 *
 * ITIL-aligned lifecycle:
 *   new → under_investigation → root_cause_identified → known_error → change_required → resolved → closed
 */
enum ProblemStatus {
  new
  under_investigation
  root_cause_identified
  known_error
  change_required
  resolved
  closed
}

/**
 * ProblemNoteType — classifies investigation notes for KEDB filtering.
 *
 *   investigation — general investigation notes and hypotheses
 *   rca           — formal root cause analysis writeup
 *   workaround    — documented workaround steps
 *   general       — miscellaneous note
 */
enum ProblemNoteType {
  investigation
  rca
  workaround
  general
}

/**
 * Problem — a first-class ITIL record representing recurring or systemic issues.
 *
 * Design principles:
 *  - Separate from Ticket and Incident: problems are investigative records, not
 *    reactive support items. They track root cause analysis over days/weeks.
 *  - isKnownError: set true when status reaches known_error or later, signalling
 *    the problem is entered in the Known Error Database (KEDB).
 *  - rootCause / workaround: long-form Markdown text fields.
 *  - affectedService: free-text placeholder. Future: FK to a CMDB ServiceCI table.
 *  - linkedChangeRef: change request number / URL. Future: FK to Change model.
 *  - ownerId: the problem manager accountable for driving the investigation.
 *  - assignedToId: the analyst actively doing the investigation.
 *  - problemNumber: generated via ticket_counter series "problem" → PRB-NNNN format.
 *
 * Recurring incident clustering (future-ready):
 *  - Linked incidents are stored in ProblemIncidentLink.
 *  - A background job can compute cluster metadata (common affected system,
 *    recurrence count, MTTR) and store it on the Problem record in the future.
 *  - The API computes a lightweight clusterHint at query time from linked incidents.
 */
model Problem {
  id            Int           @id @default(autoincrement())
  problemNumber String        @unique @map("problem_number")
  title         String
  description   String?
  status        ProblemStatus @default(new)
  priority      TicketPriority @default(medium)

  /// True when root cause is identified and entered into KEDB (known_error status or later)
  isKnownError  Boolean @default(false) @map("is_known_error")

  /// Root cause analysis narrative (Markdown)
  rootCause     String? @map("root_cause")
  /// Documented workaround for impacted services and linked incidents (Markdown)
  workaround    String?

  /// Affected service or CI name. Free-text; FK to CMDB ServiceCI in a future phase.
  affectedService String? @map("affected_service")

  /// Reference to the change request that will permanently fix this problem.
  /// Stored as a string (e.g. "CHG-0042") until the Change module has a FK.
  linkedChangeRef String? @map("linked_change_ref")

  /// Problem Manager — accountable for the investigation lifecycle
  ownerId  String? @map("owner_id")
  owner    User?   @relation("ProblemOwner", fields: [ownerId], references: [id])

  /// Primary analyst actively investigating
  assignedToId String? @map("assigned_to_id")
  assignedTo   User?   @relation("ProblemAssignee", fields: [assignedToId], references: [id])

  /// Responsible team
  teamId Int?  @map("team_id")
  team   Team? @relation(fields: [teamId], references: [id], onDelete: SetNull)

  resolvedAt DateTime? @map("resolved_at")
  closedAt   DateTime? @map("closed_at")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  linkedIncidents ProblemIncidentLink[]
  notes           ProblemNote[]
  events          ProblemEvent[]
  ciLinks         ProblemCiLink[]

  @@index([status])
  @@index([priority])
  @@index([isKnownError])
  @@index([ownerId])
  @@index([assignedToId])
  @@map("problem")
}

/**
 * ProblemIncidentLink — junction table linking problems to related incidents.
 *
 * An incident can be linked to multiple problems (rare but valid in ITIL).
 * A problem aggregates one or more incidents that share a root cause.
 * linkedAt / linkedById provide an audit trail for the association.
 */
model ProblemIncidentLink {
  id         Int      @id @default(autoincrement())
  problemId  Int      @map("problem_id")
  problem    Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
  incidentId Int      @map("incident_id")
  incident   Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  linkedAt   DateTime @default(now()) @map("linked_at")
  linkedById String?  @map("linked_by_id")
  linkedBy   User?    @relation("ProblemLinkLinkedBy", fields: [linkedById], references: [id])

  @@unique([problemId, incidentId])
  @@index([problemId])
  @@index([incidentId])
  @@map("problem_incident_link")
}

/**
 * ProblemNote — a typed investigation note on a Problem.
 *
 * Separate from the main description so that RCA writeups, workarounds,
 * and investigation logs can be tracked and filtered independently.
 * Supports the Known Error Database (KEDB) export pattern.
 */
model ProblemNote {
  id        Int             @id @default(autoincrement())
  problemId Int             @map("problem_id")
  problem   Problem         @relation(fields: [problemId], references: [id], onDelete: Cascade)
  noteType  ProblemNoteType @default(general) @map("note_type")
  body      String
  bodyHtml  String?         @map("body_html")
  authorId  String?         @map("author_id")
  author    User?           @relation("ProblemNoteAuthor", fields: [authorId], references: [id])
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([problemId, noteType])
  @@map("problem_note")
}

/**
 * ProblemEvent — append-only audit trail for every state transition and action.
 *
 * Intentionally separate from AuditEvent (ticket-scoped) and IncidentEvent.
 * action naming: "problem.<verb>" — e.g. "problem.created", "problem.status_changed".
 */
model ProblemEvent {
  id        Int      @id @default(autoincrement())
  problemId Int      @map("problem_id")
  problem   Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
  actorId   String?  @map("actor_id")
  actor     User?    @relation("ProblemEventActor", fields: [actorId], references: [id])
  action    String
  meta      Json     @default("{}")
  createdAt DateTime @default(now())

  @@index([problemId, createdAt])
  @@map("problem_event")
}

// ── Service Catalog ────────────────────────────────────────────────────────────

/**
 * CatalogCategory — groups related catalog items into sections.
 *
 * Position controls display order. Inactive categories are hidden from users
 * but retained for historical request references.
 */
model CatalogCategory {
  id          Int           @id @default(autoincrement())
  name        String
  slug        String        @unique
  description String?
  position    Int           @default(0)
  isActive    Boolean       @default(true) @map("is_active")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  items CatalogItem[]

  @@index([isActive])
  @@map("catalog_category")
}

/**
 * CatalogItem — a single service offering that users can request.
 *
 * Design principles:
 *  - shortDescription: one-line summary shown on catalog cards.
 *  - description: rich detail shown on the item's detail page.
 *  - requestorInstructions: shown to the user before submitting (SLAs, notes).
 *  - formSchema: JSON array of FormField definitions. Rendered client-side into
 *    a dynamic form. Submitted values are stored in ServiceRequest.formData.
 *  - requiresApproval + approvalMode + approverIds: catalog-level approval config.
 *    When set, every submitted request from this item goes through the approval
 *    engine with these approvers before fulfillment begins.
 *  - fulfillmentTeamId: the team auto-assigned to requests from this item.
 *  - position: display order within the category.
 *  - icon: optional emoji or short string used as a visual marker on cards.
 */
model CatalogItem {
  id                   Int              @id @default(autoincrement())
  name                 String
  shortDescription     String?          @map("short_description")
  description          String?
  categoryId           Int?             @map("category_id")
  category             CatalogCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  isActive             Boolean          @default(true)  @map("is_active")
  requestorInstructions String?         @map("requestor_instructions")

  /// Support team auto-assigned to fulfillment tasks for this item
  fulfillmentTeamId    Int?   @map("fulfillment_team_id")
  fulfillmentTeam      Team?  @relation("CatalogItemFulfillmentTeam", fields: [fulfillmentTeamId], references: [id], onDelete: SetNull)

  /// Whether requests submitted from this item require approval
  requiresApproval     Boolean  @default(false) @map("requires_approval")
  /// "all" = every approver must sign off | "any" = first approval suffices
  approvalMode         String   @default("all") @map("approval_mode")
  /// Ordered list of User.id strings who must approve (stored on the item)
  approverIds          String[] @default([]) @map("approver_ids")

  /// JSON array of FormField objects — defines the dynamic request form
  formSchema Json @default("[]") @map("form_schema")

  position Int     @default(0)
  icon     String? /// emoji or short label shown on catalog cards

  createdById String?  @map("created_by_id")
  createdBy   User?    @relation("CatalogItemCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  requests ServiceRequest[]

  @@index([categoryId])
  @@index([isActive])
  @@map("catalog_item")
}

// ── CMDB — Configuration Management Database ───────────────────────────────────

/**
 * CiType — the class of a Configuration Item.
 * Drives icon selection, relationship validation, and impact analysis.
 */
enum CiType {
  server
  workstation
  network_device
  application
  service
  database
  storage
  virtual_machine
  container
  printer
  mobile_device
  other
}

/** CiEnvironment — which deployment tier this CI belongs to. */
enum CiEnvironment {
  production
  staging
  development
  test
  disaster_recovery
}

/**
 * CiCriticality — business impact if this CI fails.
 * Maps to ITIL priority: critical → P1, high → P2, medium → P3, low → P4.
 */
enum CiCriticality {
  critical
  high
  medium
  low
}

/**
 * CiStatus — operational lifecycle state of a Configuration Item.
 *
 * active         — in production, healthy
 * maintenance    — under scheduled maintenance; not expected to serve traffic
 * planned        — approved, not yet deployed
 * retired        — decommissioned but record retained for audit history
 * decommissioned — physically removed / license surrendered
 */
enum CiStatus {
  active
  maintenance
  planned
  retired
  decommissioned
}

/**
 * CiRelationshipType — directed relationship between two CIs.
 *
 * Direction is always fromCi → toCi:
 *   depends_on    fromCI requires toCi to function (application depends_on database)
 *   hosts         fromCI runs/hosts toCi (server hosts virtual_machine)
 *   is_parent_of  fromCI is the logical parent of toCi (service is_parent_of components)
 *   connects_to   network-level connection (switch connects_to server)
 *   backs_up      fromCI backs up toCi (backup server backs_up primary)
 */
enum CiRelationshipType {
  depends_on
  hosts
  is_parent_of
  connects_to
  backs_up
}

/**
 * ConfigItem — a Configuration Item in the CMDB.
 *
 * Design principles:
 *  - ciNumber: generated as CI-NNNN via ticket_counter series "ci".
 *  - type/environment/criticality/status: enum-driven for structured filtering
 *    and future impact analysis (which tickets/incidents affect critical CIs?).
 *  - tags: free-form string array for ad-hoc grouping (e.g. ["finance", "sox"]).
 *  - owner: the human accountable for this CI's health (not the support team).
 *  - team: the support team responsible for operating this CI.
 *  - affectedSystem on Ticket/Incident/Problem is preserved as-is; CI links
 *    are additive and progressively replace the free-text field.
 */
model ConfigItem {
  id          Int           @id @default(autoincrement())
  ciNumber    String        @unique @map("ci_number")
  name        String
  type        CiType
  environment CiEnvironment @default(production)
  criticality CiCriticality @default(medium)
  status      CiStatus      @default(active)
  description String?
  tags        String[]      @default([])

  ownerId String? @map("owner_id")
  owner   User?   @relation("CiOwner", fields: [ownerId], references: [id])

  teamId Int?  @map("team_id")
  team   Team? @relation(fields: [teamId], references: [id], onDelete: SetNull)

  createdById String?  @map("created_by_id")
  createdBy   User?    @relation("CiCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Directed relationships originating from this CI
  relationshipsFrom CiRelationship[] @relation("RelationshipFrom")
  // Directed relationships pointing to this CI
  relationshipsTo   CiRelationship[] @relation("RelationshipTo")

  // Impact linkage — records that reference this CI
  ticketLinks   TicketCiLink[]
  incidentLinks IncidentCiLink[]
  problemLinks  ProblemCiLink[]

  events CiEvent[]

  @@index([type])
  @@index([status])
  @@index([criticality])
  @@index([environment])
  @@index([ownerId])
  @@map("config_item")
}

/**
 * CiRelationship — a directed typed edge between two ConfigItems.
 *
 * Unique on (fromCiId, toCiId, type) so the same relationship type cannot
 * be duplicated, but two CIs can have relationships of different types.
 */
model CiRelationship {
  id       Int                @id @default(autoincrement())
  fromCiId Int                @map("from_ci_id")
  fromCi   ConfigItem         @relation("RelationshipFrom", fields: [fromCiId], references: [id], onDelete: Cascade)
  toCiId   Int                @map("to_ci_id")
  toCi     ConfigItem         @relation("RelationshipTo", fields: [toCiId], references: [id], onDelete: Cascade)
  type     CiRelationshipType

  createdAt   DateTime @default(now())
  createdById String?  @map("created_by_id")

  @@unique([fromCiId, toCiId, type])
  @@index([fromCiId])
  @@index([toCiId])
  @@map("ci_relationship")
}

/** TicketCiLink — links a ticket to one or more CIs for impact tracking. */
model TicketCiLink {
  id       Int        @id @default(autoincrement())
  ticketId Int        @map("ticket_id")
  ticket   Ticket     @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  ciId     Int        @map("ci_id")
  ci       ConfigItem @relation(fields: [ciId], references: [id], onDelete: Cascade)
  linkedAt DateTime   @default(now()) @map("linked_at")

  @@unique([ticketId, ciId])
  @@index([ticketId])
  @@index([ciId])
  @@map("ticket_ci_link")
}

/** IncidentCiLink — links an incident to one or more affected CIs. */
model IncidentCiLink {
  id         Int        @id @default(autoincrement())
  incidentId Int        @map("incident_id")
  incident   Incident   @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  ciId       Int        @map("ci_id")
  ci         ConfigItem @relation(fields: [ciId], references: [id], onDelete: Cascade)
  linkedAt   DateTime   @default(now()) @map("linked_at")

  @@unique([incidentId, ciId])
  @@index([incidentId])
  @@index([ciId])
  @@map("incident_ci_link")
}

/** ProblemCiLink — links a problem to one or more root-cause CIs. */
model ProblemCiLink {
  id        Int        @id @default(autoincrement())
  problemId Int        @map("problem_id")
  problem   Problem    @relation(fields: [problemId], references: [id], onDelete: Cascade)
  ciId      Int        @map("ci_id")
  ci        ConfigItem @relation(fields: [ciId], references: [id], onDelete: Cascade)
  linkedAt  DateTime   @default(now()) @map("linked_at")

  @@unique([problemId, ciId])
  @@index([problemId])
  @@index([ciId])
  @@map("problem_ci_link")
}

/**
 * CiEvent — append-only audit trail for every change to a ConfigItem.
 * action naming: "ci.<verb>" — e.g. "ci.created", "ci.status_changed".
 */
model CiEvent {
  id        Int        @id @default(autoincrement())
  ciId      Int        @map("ci_id")
  ci        ConfigItem @relation(fields: [ciId], references: [id], onDelete: Cascade)
  actorId   String?    @map("actor_id")
  actor     User?      @relation("CiEventActor", fields: [actorId], references: [id])
  action    String
  meta      Json       @default("{}")
  createdAt DateTime   @default(now())

  @@index([ciId, createdAt])
  @@map("ci_event")
}

// ── Notification System ────────────────────────────────────────────────────────

/**
 * Notification — a single per-user notification record.
 *
 * event naming: "<domain>.<verb>" — e.g. "ticket.assigned", "approval.requested".
 * entityType / entityId / entityUrl provide navigation context for the UI.
 * readAt null means unread.
 */
model Notification {
  id         Int      @id @default(autoincrement())
  userId     String   @map("user_id")
  user       User     @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  event      String   @map("event")
  title      String   @map("title")
  body       String?  @map("body")
  entityType String?  @map("entity_type")
  entityId   String?  @map("entity_id")
  entityUrl  String?  @map("entity_url")
  readAt     DateTime? @map("read_at")
  createdAt  DateTime @default(now()) @map("created_at")
  deliveries NotificationDelivery[]

  @@index([userId, readAt])
  @@index([userId, createdAt(sort: Desc)])
  @@map("notification")
}

/**
 * NotificationDelivery — records the delivery attempt for each channel.
 *
 * channel: "in_app" | "email" | "slack" | "webhook"
 * status: "pending" | "sent" | "failed" | "skipped"
 *
 * For in_app, delivery is considered "sent" as soon as the Notification row
 * is created (the record itself is the delivery). For async channels (email,
 * slack, webhook) this row tracks the send attempt.
 */
model NotificationDelivery {
  id             Int          @id @default(autoincrement())
  notificationId Int          @map("notification_id")
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  channel        String       @map("channel")
  status         String       @default("pending") @map("status")
  error          String?      @map("error")
  sentAt         DateTime?    @map("sent_at")
  createdAt      DateTime     @default(now()) @map("created_at")

  @@index([notificationId])
  @@index([channel, status])
  @@map("notification_delivery")
}

/**
 * NotificationRule — admin-configurable rules that map events to channels and
 * recipient strategies. Foundation for a rule-based notification engine.
 *
 * recipientType: "assignee" | "reporter" | "commander" | "team" | "role" | "all_agents"
 * channels: JSON array of channel names — e.g. ["in_app", "email"]
 */
model NotificationRule {
  id            Int      @id @default(autoincrement())
  name          String   @map("name")
  description   String?  @map("description")
  event         String   @map("event")
  channels      String[] @map("channels")
  recipientType String   @default("assignee") @map("recipient_type")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([event, isActive])
  @@map("notification_rule")
}
